# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js build output
.next/
out/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Docs needed for developer context
docs/

# Source content (originals): kept locally, never committed
/content/

# Optimized content (WebP responsive variants): generated on the VPS by
# `npm run content`, never committed.
/public/content/

# Manifest: regenerated by prebuild/predev from /content on whichever machine
# is running the build. Never committed.
/src/content/manifest.json
